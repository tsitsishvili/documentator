{
    "name": "tsitsishvili/documentator",
    "description": "Auto-inferred, interactive API documentation for Laravel. Scans routes, FormRequests, API Resources and return types, lets you override with PHP attributes, and serves a built-in explorer or Scalar UI backed by OpenAPI 3.1.",
    "keywords": ["laravel", "php", "api", "api-documentation", "documentation", "openapi", "openapi31", "swagger", "scalar", "postman", "php-attributes", "laravel-package", "rest-api"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0",
        "illuminate/console": "^12.0 || ^13.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "spatie/laravel-data": "^4.23"
    },
    "suggest": {
        "spatie/laravel-data": "Auto-document request/response Data objects (^4.0).",
        "spatie/laravel-query-builder": "Auto-document allowed filters, sorts, includes and sparse fieldsets (^6.0)."
    },
    "autoload": {
        "psr-4": {
            "Tsitsishvili\\Documentator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tsitsishvili\\Documentator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tsitsishvili\\Documentator\\DocumentatorServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "lint:test": "pint --test",
        "analyse": "php -d memory_limit=1G vendor/bin/phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
